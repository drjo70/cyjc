{
  "name": "cyjc-family-tree",
  "version": "1.0.0",
  "description": "창녕조씨 족보 시스템 - 카페24 호스팅용",
  "author": "조영국 <jo@jou.kr>",
  "keywords": ["genealogy", "family-tree", "korean", "cafe24"],
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --ip 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "test": "curl http://localhost:3000",
    "git:init": "git init && git add . && git commit -m 'Initial commit'",
    "git:commit": "git add . && git commit -m",
    "git:status": "git status",
    "git:log": "git log --oneline",
    "logs:setup": "mkdir -p logs",
    "cafe24:setup": "mkdir -p public_html && cp -r dist/* public_html/",
    "cafe24:backup": "tar -czf cyjc-backup-$(date +%Y%m%d).tar.gz dist/ public/ src/"
  },
  "dependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20250705.0",
    "@hono/vite-cloudflare-pages": "^0.4.2",
    "vite": "^5.0.0",
    "wrangler": "^3.78.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/changnyeongjo/family-tree"
  },
  "license": "MIT"
}